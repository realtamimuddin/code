{
  "manifest_version": 3,
  "name": "PR Code Review Highlights",
  "version": "0.1.0",
  "description": "Real-time collaborative highlights on GitHub pull request pages.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://github.com/*",
    "http://localhost:8787/*",
    "ws://localhost:8787/*",
    "wss://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "PR Highlights",
    "default_popup": "popup/index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options/index.html"
}
